{
  "info": {
    "name": "Resume ATS API",
    "description": "Resume-Agent-MVP ATS API. Uses the ATS System 6-dimension rule engine as the single scoring source.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "description": "Local or deployed Resume-Agent-MVP server URL"
    }
  ],
  "item": [
    {
      "name": "0. Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/v1/ats/health",
        "description": "Confirms server and ATS System rule-engine status."
      }
    },
    {
      "name": "1. Score Report - JSON",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/v1/score",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resumeText\": \"Paste resume plain text here\",\n  \"jobTitle\": \"Software Engineer\",\n  \"jdText\": \"Paste job description here\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Primary product endpoint. Scores with the local ATS System engine and returns a public report."
      }
    },
    {
      "name": "2. Score Report - File Upload",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/v1/score",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "description": "PDF / DOCX / TXT resume" },
            { "key": "jobTitle", "value": "Product Manager", "type": "text" },
            { "key": "jdText", "value": "Paste job description here", "type": "text" }
          ]
        },
        "description": "Uploads a resume file, scores it with ATS System, and returns a public report."
      }
    },
    {
      "name": "3. ATS System Proxy",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/v1/ats/rule",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resumeText\": \"Paste resume plain text here\",\n  \"jobTitle\": \"Data Analyst\",\n  \"jdText\": \"Paste job description here\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Calls hosted ATS System when configured, otherwise falls back to the local ATS System engine."
      }
    },
    {
      "name": "4. ATS System Local Only",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/v1/ats/rule-local",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resumeText\": \"Paste resume plain text here\",\n  \"jobTitle\": \"Data Analyst\",\n  \"jdText\": \"Paste job description here\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Forces local ATS System scoring."
      }
    },
    {
      "name": "5. Parse File Only",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/parse-file",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "description": "PDF / DOCX / TXT" },
            { "key": "type", "value": "pdf", "type": "text", "description": "pdf | docx | txt" }
          ]
        },
        "description": "Extracts plain text from an uploaded resume file."
      }
    }
  ]
}

{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/resume/[id]",
      "regex": "^/api/resume/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/resume/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/resume/[id]/mark-paid",
      "regex": "^/api/resume/([^/]+?)/mark\\-paid(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/resume/(?<nxtPid>[^/]+?)/mark\\-paid(?:/)?$"
    },
    {
      "page": "/api/v1/reports/[reportId]/debug",
      "regex": "^/api/v1/reports/([^/]+?)/debug(?:/)?$",
      "routeKeys": {
        "nxtPreportId": "nxtPreportId"
      },
      "namedRegex": "^/api/v1/reports/(?<nxtPreportId>[^/]+?)/debug(?:/)?$"
    },
    {
      "page": "/api/v1/reports/[reportId]/mark-paid",
      "regex": "^/api/v1/reports/([^/]+?)/mark\\-paid(?:/)?$",
      "routeKeys": {
        "nxtPreportId": "nxtPreportId"
      },
      "namedRegex": "^/api/v1/reports/(?<nxtPreportId>[^/]+?)/mark\\-paid(?:/)?$"
    },
    {
      "page": "/api/v1/reports/[reportId]/public",
      "regex": "^/api/v1/reports/([^/]+?)/public(?:/)?$",
      "routeKeys": {
        "nxtPreportId": "nxtPreportId"
      },
      "namedRegex": "^/api/v1/reports/(?<nxtPreportId>[^/]+?)/public(?:/)?$"
    },
    {
      "page": "/api/v1/reports/[reportId]/unlock",
      "regex": "^/api/v1/reports/([^/]+?)/unlock(?:/)?$",
      "routeKeys": {
        "nxtPreportId": "nxtPreportId"
      },
      "namedRegex": "^/api/v1/reports/(?<nxtPreportId>[^/]+?)/unlock(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/analyzing",
      "regex": "^/analyzing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/analyzing(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/payment",
      "regex": "^/payment(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/payment(?:/)?$"
    },
    {
      "page": "/report",
      "regex": "^/report(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/report(?:/)?$"
    },
    {
      "page": "/result",
      "regex": "^/result(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/result(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}